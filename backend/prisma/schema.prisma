generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum EmploymentStatus {
  ONBOARDING
  ACTIVE
  PROBATION
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
  WORK_FROM_HOME
}

enum AttendanceWorkMode {
  OFFICE
  WORK_FROM_HOME
}

enum HolidayType {
  PUBLIC
  COMPANY
  OPTIONAL
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveDayType {
  FULL_DAY
  HALF_DAY
}

enum PayrollStatus {
  GENERATED
  REVIEWED
  PAID
}

enum AnnouncementAudience {
  ALL
  SUPER_ADMIN
  HR_ADMIN
  MANAGER
  EMPLOYEE
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

enum InterviewMode {
  PHONE
  VIDEO
  IN_PERSON
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum PerformanceReviewStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
}

enum FeedbackCategory {
  GENERAL
  PRAISE
  IMPROVEMENT
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  name                String
  passwordHash        String?
  status              AccountStatus        @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  roles               UserRole[]
  passwordResetTokens PasswordResetToken[]
  employee            Employee?
  uploadedDocuments   EmployeeDocument[]   @relation("UploadedEmployeeDocuments")
  notifications       Notification[]
  generatedPayrolls   Payroll[]            @relation("GeneratedPayrolls")
  announcements       Announcement[]       @relation("CreatedAnnouncements")
  createdJobs         Job[]                @relation("CreatedJobs")
  createdGoals        Goal[]               @relation("CreatedGoals")

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employees    Employee[]
  designations Designation[]
  jobs         Job[]

  @@map("departments")
}

model Designation {
  id           String      @id @default(uuid())
  title        String
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees    Employee[]
  jobs         Job[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([title, departmentId])
  @@index([departmentId])
  @@map("designations")
}

model Employee {
  id                 String              @id @default(uuid())
  employeeCode       String              @unique
  userId             String?             @unique
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName          String
  lastName           String
  workEmail          String              @unique
  personalEmail      String?
  phone              String?
  dateOfBirth        DateTime?
  dateOfJoining      DateTime
  dateOfExit         DateTime?
  status             EmploymentStatus    @default(ACTIVE)
  location           String?
  departmentId       String?
  department         Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId      String?
  designation        Designation?        @relation(fields: [designationId], references: [id], onDelete: SetNull)
  managerId          String?
  manager            Employee?           @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports            Employee[]          @relation("EmployeeManager")
  emergencyContacts  EmergencyContact[]
  documents          EmployeeDocument[]
  attendanceRecords  Attendance[]
  leaveRequests      LeaveRequest[]      @relation("EmployeeLeaveRequests")
  reviewedLeaves     LeaveRequest[]      @relation("ReviewedLeaveRequests")
  leaveBalances      LeaveBalance[]
  salaries           Salary[]
  payrollItems       PayrollItem[]
  payslips           Payslip[]
  interviews         Interview[]         @relation("InterviewInterviewer")
  goals              Goal[]              @relation("EmployeeGoals")
  performanceReviews PerformanceReview[] @relation("EmployeePerformanceReviews")
  reviewsGiven       PerformanceReview[] @relation("ReviewerPerformanceReviews")
  feedbackReceived   Feedback[]          @relation("EmployeeFeedbackReceived")
  feedbackAuthored   Feedback[]          @relation("EmployeeFeedbackAuthored")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([departmentId])
  @@index([designationId])
  @@index([managerId])
  @@map("employees")
}

model EmergencyContact {
  id           String   @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name         String
  relationship String
  phone        String
  email        String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@map("emergency_contacts")
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documentType String
  fileName     String
  fileUrl      String   @db.Text
  mimeType     String?
  sizeBytes    Int?
  notes        String?
  uploadedById String?
  uploadedBy   User?    @relation("UploadedEmployeeDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([employeeId])
  @@index([uploadedById])
  @@map("employee_documents")
}

model Shift {
  id                  String       @id @default(uuid())
  name                String       @unique
  startTime           String
  endTime             String
  lateAfterMinutes    Int          @default(15)
  halfDayAfterMinutes Int          @default(240)
  isDefault           Boolean      @default(false)
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  attendanceRecords   Attendance[]

  @@map("shifts")
}

model Holiday {
  id          String      @id @default(uuid())
  name        String
  date        DateTime    @unique @db.Date
  type        HolidayType @default(PUBLIC)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("holidays")
}

model Attendance {
  id         String             @id @default(uuid())
  employeeId String
  employee   Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId    String?
  shift      Shift?             @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  date       DateTime           @db.Date
  clockInAt  DateTime?
  clockOutAt DateTime?
  status     AttendanceStatus   @default(PRESENT)
  workMode   AttendanceWorkMode @default(OFFICE)
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([shiftId])
  @@index([date])
  @@map("attendance")
}

model LeaveType {
  id                     String         @id @default(uuid())
  name                   String         @unique
  description            String?
  defaultAnnualAllowance Float          @default(0)
  isPaid                 Boolean        @default(true)
  requiresApproval       Boolean        @default(true)
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  leaveRequests          LeaveRequest[]
  leaveBalances          LeaveBalance[]

  @@map("leave_types")
}

model LeaveRequest {
  id           String             @id @default(uuid())
  employeeId   String
  employee     Employee           @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId  String
  leaveType    LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  startDate    DateTime           @db.Date
  endDate      DateTime           @db.Date
  dayType      LeaveDayType       @default(FULL_DAY)
  totalDays    Float
  reason       String
  status       LeaveRequestStatus @default(PENDING)
  reviewerId   String?
  reviewer     Employee?          @relation("ReviewedLeaveRequests", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  decisionNote String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([reviewerId])
  @@index([startDate])
  @@index([status])
  @@map("leave_requests")
}

model LeaveBalance {
  id             String    @id @default(uuid())
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId    String
  leaveType      LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year           Int
  openingBalance Float     @default(0)
  accrued        Float     @default(0)
  used           Float     @default(0)
  pending        Float     @default(0)
  available      Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@map("leave_balances")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  category  String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Salary {
  id            String        @id @default(uuid())
  employeeId    String        @unique
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  baseSalary    Float
  allowances    Float         @default(0)
  deductions    Float         @default(0)
  effectiveFrom DateTime      @db.Date
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  payrollItems  PayrollItem[]

  @@index([employeeId])
  @@map("salaries")
}

model Payroll {
  id              String        @id @default(uuid())
  month           Int
  year            Int
  status          PayrollStatus @default(GENERATED)
  generatedById   String?
  generatedBy     User?         @relation("GeneratedPayrolls", fields: [generatedById], references: [id], onDelete: SetNull)
  itemCount       Int           @default(0)
  totalGross      Float         @default(0)
  totalDeductions Float         @default(0)
  totalNet        Float         @default(0)
  generatedAt     DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           PayrollItem[]
  payslips        Payslip[]

  @@unique([month, year])
  @@index([generatedById])
  @@index([year, month])
  @@map("payrolls")
}

model PayrollItem {
  id              String   @id @default(uuid())
  payrollId       String
  payroll         Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  salaryId        String?
  salary          Salary?  @relation(fields: [salaryId], references: [id], onDelete: SetNull)
  baseSalary      Float
  allowances      Float    @default(0)
  deductions      Float    @default(0)
  grossPay        Float
  totalDeductions Float
  netPay          Float
  notes           String?
  createdAt       DateTime @default(now())
  payslip         Payslip?

  @@unique([payrollId, employeeId])
  @@index([payrollId])
  @@index([employeeId])
  @@index([salaryId])
  @@map("payroll_items")
}

model Payslip {
  id              String      @id @default(uuid())
  payrollId       String
  payroll         Payroll     @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  payrollItemId   String      @unique
  payrollItem     PayrollItem @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payslipNumber   String      @unique
  grossPay        Float
  totalDeductions Float
  netPay          Float
  issuedAt        DateTime    @default(now())
  createdAt       DateTime    @default(now())

  @@unique([payrollId, employeeId])
  @@index([payrollId])
  @@index([employeeId])
  @@map("payslips")
}

model Announcement {
  id          String               @id @default(uuid())
  title       String
  message     String               @db.Text
  audience    AnnouncementAudience @default(ALL)
  isPublished Boolean              @default(true)
  publishedAt DateTime             @default(now())
  createdById String?
  createdBy   User?                @relation("CreatedAnnouncements", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([audience])
  @@index([isPublished])
  @@index([createdById])
  @@map("announcements")
}

model Job {
  id             String           @id @default(uuid())
  title          String
  description    String           @db.Text
  departmentId   String?
  department     Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId  String?
  designation    Designation?     @relation(fields: [designationId], references: [id], onDelete: SetNull)
  location       String?
  employmentType String?
  status         JobStatus        @default(OPEN)
  createdById    String?
  createdBy      User?            @relation("CreatedJobs", fields: [createdById], references: [id], onDelete: SetNull)
  applications   JobApplication[]
  offers         Offer[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([departmentId])
  @@index([designationId])
  @@index([createdById])
  @@index([status])
  @@map("jobs")
}

model Candidate {
  id             String           @id @default(uuid())
  firstName      String
  lastName       String
  email          String           @unique
  phone          String?
  source         String?
  resumeUrl      String?          @db.Text
  currentCompany String?
  currentTitle   String?
  applications   JobApplication[]
  interviews     Interview[]
  offers         Offer[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([email])
  @@map("candidates")
}

model JobApplication {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status      ApplicationStatus @default(APPLIED)
  appliedAt   DateTime          @default(now())
  notes       String?
  interviews  Interview[]
  offers      Offer[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([status])
  @@map("applications")
}

model Interview {
  id            String          @id @default(uuid())
  applicationId String
  application   JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewerId String?
  interviewer   Employee?       @relation("InterviewInterviewer", fields: [interviewerId], references: [id], onDelete: SetNull)
  scheduledAt   DateTime
  mode          InterviewMode
  location      String?
  status        InterviewStatus @default(SCHEDULED)
  feedback      String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([applicationId])
  @@index([candidateId])
  @@index([interviewerId])
  @@index([scheduledAt])
  @@index([status])
  @@map("interviews")
}

model Offer {
  id            String         @id @default(uuid())
  applicationId String         @unique
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  offeredSalary Float?
  startDate     DateTime?      @db.Date
  status        OfferStatus    @default(DRAFT)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@map("offers")
}

model Goal {
  id          String     @id @default(uuid())
  employeeId  String
  employee    Employee   @relation("EmployeeGoals", fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  description String?    @db.Text
  status      GoalStatus @default(NOT_STARTED)
  progress    Int        @default(0)
  startDate   DateTime?  @db.Date
  dueDate     DateTime?  @db.Date
  createdById String?
  createdBy   User?      @relation("CreatedGoals", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([employeeId])
  @@index([createdById])
  @@index([status])
  @@index([dueDate])
  @@map("goals")
}

model PerformanceReview {
  id                String                  @id @default(uuid())
  employeeId        String
  employee          Employee                @relation("EmployeePerformanceReviews", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewerId        String?
  reviewer          Employee?               @relation("ReviewerPerformanceReviews", fields: [reviewerId], references: [id], onDelete: SetNull)
  cycle             String
  reviewPeriodStart DateTime                @db.Date
  reviewPeriodEnd   DateTime                @db.Date
  rating            Int
  summary           String                  @db.Text
  strengths         String?                 @db.Text
  improvements      String?                 @db.Text
  status            PerformanceReviewStatus @default(DRAFT)
  submittedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([employeeId])
  @@index([reviewerId])
  @@index([status])
  @@index([cycle])
  @@map("performance_reviews")
}

model Feedback {
  id         String           @id @default(uuid())
  employeeId String
  employee   Employee         @relation("EmployeeFeedbackReceived", fields: [employeeId], references: [id], onDelete: Cascade)
  authorId   String?
  author     Employee?        @relation("EmployeeFeedbackAuthored", fields: [authorId], references: [id], onDelete: SetNull)
  category   FeedbackCategory @default(GENERAL)
  message    String           @db.Text
  isPrivate  Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([employeeId])
  @@index([authorId])
  @@index([category])
  @@map("feedback")
}
